# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv*/

# Data files (too large for git)
/data/
/research/data/
*.bin
enwik8
enwik8.zip
# Allow the Azure pipeline data scaffolding (manifests, scripts, configs)
!research/cloud/azure/data/
!research/cloud/azure/data/**

# Model checkpoints (binary, often hundreds of MB)
checkpoints/
research/checkpoints/
*.pt
*.pth
*.safetensors
*.onnx

# Run-specific artifacts
logs/
results/*progress*.json
results/*final*.json
research/results/

# Generated CUDA shared libs
cuda/*.so
cuda/*.dll
cuda/*.lib
cuda/*.exp
cuda/*.pdb

# Archives & misc
*.zip
*.tar
*.tar.gz
files*.zip
research/_tmp_*.py
staged_changes/

# Nested accidental working copy (carries its own .git); never track from parent
/TropFormer/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Byte-compiled
*.pyc

# Logs
*.log
